#!/usr/bin/env python3
"""Control helpers for the local CMS D0 analysis workspace."""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Any

import yaml


ROOT = Path(__file__).resolve().parents[1]
WORKSPACE = ROOT / "research" / "cms-d0-analysis"
REGISTRY = WORKSPACE / "registry.yaml"
LEDGER = WORKSPACE / "logs" / "analysis-ledger.jsonl"
PLOTS = WORKSPACE / "plots"
GALLERY = WORKSPACE / "PLOTS.md"
SUMMARY = WORKSPACE / "SUPERVISOR_SUMMARY.md"


def utc_now() -> str:
    return dt.datetime.now(dt.UTC).strftime("%Y-%m-%dT%H:%M:%SZ")


def load_registry() -> dict[str, Any]:
    if not REGISTRY.exists():
        raise SystemExit(f"Missing CMS registry: {REGISTRY}")
    data = yaml.safe_load(REGISTRY.read_text(encoding="utf-8"))
    if not isinstance(data, dict):
        raise SystemExit(f"Invalid CMS registry: {REGISTRY}")
    return data


def rel(path: Path) -> str:
    try:
        return path.resolve().relative_to(ROOT.resolve()).as_posix()
    except ValueError:
        return str(path.resolve())


def git_head() -> str:
    proc = subprocess.run(
        ["git", "rev-parse", "--short", "HEAD"],
        cwd=str(ROOT),
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    return proc.stdout.strip() if proc.returncode == 0 else ""


def command_status(_args: argparse.Namespace) -> int:
    data = load_registry()
    analysis = data.get("analysis") or {}
    runs = data.get("runs") or []
    datasets = data.get("datasets") or []
    outputs = data.get("outputs") or {}
    print(f"analysis: {analysis.get('id', 'cms-d0-mass-peak')}")
    print(f"status: {analysis.get('status', 'unknown')}")
    print(f"phase: {analysis.get('current_phase', 'unknown')}")
    print(f"workspace: {rel(WORKSPACE)}")
    print(f"runs: {len(runs)}")
    print(f"datasets: {len(datasets)}")
    print(f"plots: {len(plot_files())}")
    print(f"gallery: {outputs.get('gallery', rel(GALLERY))}")
    print(f"summary: {outputs.get('supervisor_summary', rel(SUMMARY))}")
    if head := git_head():
        print(f"agent-network git: {head}")
    return 0


def read_ledger(limit: int = 20) -> list[dict[str, Any]]:
    if not LEDGER.exists():
        return []
    rows = []
    for line in LEDGER.read_text(encoding="utf-8").splitlines():
        if not line.strip():
            continue
        try:
            rows.append(json.loads(line))
        except json.JSONDecodeError:
            rows.append({"created_utc": "", "event": "invalid-ledger-line", "detail": line[:200]})
    return rows[-limit:]


def append_ledger(event: str, detail: str = "", source: str = "", tags: list[str] | None = None) -> None:
    LEDGER.parent.mkdir(parents=True, exist_ok=True)
    row = {
        "created_utc": utc_now(),
        "event": event,
        "detail": detail,
        "source": source,
        "tags": tags or [],
    }
    with LEDGER.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(row, sort_keys=True) + "\n")


def command_ledger(args: argparse.Namespace) -> int:
    if args.event:
        append_ledger(args.event, args.detail, args.source, args.tag)
        print("CMS analysis ledger updated.")
        return 0
    rows = read_ledger(args.limit)
    if not rows:
        print("No CMS analysis ledger entries.")
        return 0
    for row in rows:
        bits = [
            row.get("created_utc", ""),
            row.get("event", ""),
            row.get("detail", ""),
        ]
        print(" | ".join(bit for bit in bits if bit))
    return 0


def plot_files() -> list[Path]:
    if not PLOTS.exists():
        return []
    exts = {".png", ".jpg", ".jpeg", ".pdf", ".svg"}
    return sorted(
        (path for path in PLOTS.rglob("*") if path.is_file() and path.suffix.lower() in exts),
        key=lambda path: path.stat().st_mtime,
        reverse=True,
    )


def plot_group(path: Path) -> str:
    try:
        rel_path = path.relative_to(PLOTS)
    except ValueError:
        return "Other"
    if len(rel_path.parts) > 1:
        return rel_path.parts[0].replace("_", " ").replace("-", " ").title()
    return "Ungrouped"


def write_gallery() -> int:
    plots = plot_files()
    lines = [
        "# Plot Gallery",
        "",
        "<!-- DOC_OWNER: generated by scripts/cms-analysisctl gallery. -->",
        "<!-- TOKEN_NOTE: regenerate instead of hand-updating when plots change. -->",
        "",
        f"Generated UTC: `{utc_now()}`",
        "",
    ]
    if not plots:
        lines.extend(["No plots registered yet.", ""])
    else:
        current_group = ""
        for path in plots:
            group = plot_group(path)
            if group != current_group:
                current_group = group
                lines.extend([f"## {group}", ""])
            stat = path.stat()
            rel_path = rel(path)
            size = stat.st_size
            lines.append(f"- [{path.name}](../../{rel_path})")
            lines.append(f"  - path: `{rel_path}`")
            lines.append(f"  - size: `{size}` bytes")
            lines.append("")
    GALLERY.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")
    append_ledger("gallery-regenerated", f"{len(plots)} plot artifacts", rel(GALLERY), ["plots"])
    print(f"Wrote {rel(GALLERY)} with {len(plots)} plot artifacts.")
    return 0


def command_gallery(_args: argparse.Namespace) -> int:
    return write_gallery()


def write_summary() -> int:
    data = load_registry()
    analysis = data.get("analysis") or {}
    runs = data.get("runs") or []
    plots = plot_files()
    recent = read_ledger(8)
    lines = [
        "# Supervisor Summary",
        "",
        "<!-- DOC_OWNER: cms-analysis-manager polished rolling supervisor buffer. -->",
        "<!-- TOKEN_NOTE: update this after meaningful plot/checkpoint changes. -->",
        "",
        "## Status",
        "",
        f"- Analysis: `{analysis.get('id', 'cms-d0-mass-peak')}`",
        f"- Status: `{analysis.get('status', 'unknown')}`",
        f"- Phase: `{analysis.get('current_phase', 'unknown')}`",
        f"- Runs in registry: `{len(runs)}`",
        f"- Registered plot artifacts: `{len(plots)}`",
        "",
        "## Latest Plots",
        "",
    ]
    if plots:
        for path in plots[:8]:
            lines.append(f"- [{path.name}](../../{rel(path)})")
    else:
        lines.append("No new plots registered yet.")
    lines.extend([
        "",
        "## Recent Analysis Ledger",
        "",
    ])
    if recent:
        for row in recent:
            detail = row.get("detail") or row.get("event") or ""
            lines.append(f"- `{row.get('created_utc', '')}` {row.get('event', '')}: {detail}")
    else:
        lines.append("- No analysis ledger entries yet.")
    lines.extend([
        "",
        "## Current Takeaways",
        "",
        "- The reproduction workspace and validation structure are ready.",
        "- Prior 2025-vs-2026 comparison outputs are context, not the task definition.",
        "- Physics conclusions should wait for reference inputs, matching plots, and checker review.",
        "",
        "## Open Items",
        "",
        "- Reference analysis source.",
        "- Canonical input files.",
        "- Required plot/fit outputs.",
        "- Selection and normalization definitions.",
        "",
        "## Next Action",
        "",
        "Collect the reference analysis inputs and run a read-only inventory before producing new plots.",
        "",
    ])
    SUMMARY.write_text("\n".join(lines), encoding="utf-8")
    append_ledger("summary-regenerated", "Supervisor summary refreshed", rel(SUMMARY), ["summary"])
    print(f"Wrote {rel(SUMMARY)}.")
    return 0


def command_summary(_args: argparse.Namespace) -> int:
    return write_summary()


def command_check(_args: argparse.Namespace) -> int:
    data = load_registry()
    failed = False
    required = [WORKSPACE / name for name in ["README.md", "RUNS.md", "DATASETS.md", "COMMANDS.md", "PLOTS.md", "CHECKLISTS.md", "SUPERVISOR_SUMMARY.md"]]
    for path in [REGISTRY, *required]:
        if not path.exists():
            failed = True
            print(f"missing: {rel(path)}", file=sys.stderr)
    for run in data.get("runs") or []:
        if not run.get("id") or not run.get("year"):
            failed = True
            print(f"incomplete run registry item: {run}", file=sys.stderr)
    if failed:
        return 1
    print("CMS analysis workspace checks passed.")
    return 0


def parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(description=__doc__)
    sub = p.add_subparsers(dest="command", required=True)

    status = sub.add_parser("status", help="Print compact CMS workspace status")
    status.set_defaults(func=command_status)

    ledger = sub.add_parser("ledger", help="List or append CMS analysis ledger entries")
    ledger.add_argument("--event", default="", help="Append an event instead of listing")
    ledger.add_argument("--detail", default="")
    ledger.add_argument("--source", default="")
    ledger.add_argument("--tag", action="append", default=[])
    ledger.add_argument("--limit", type=int, default=20)
    ledger.set_defaults(func=command_ledger)

    gallery = sub.add_parser("gallery", help="Regenerate PLOTS.md from plots/")
    gallery.set_defaults(func=command_gallery)

    summary = sub.add_parser("summary", help="Regenerate SUPERVISOR_SUMMARY.md")
    summary.set_defaults(func=command_summary)

    check = sub.add_parser("check", help="Validate workspace structure")
    check.set_defaults(func=command_check)

    return p


def main(argv: list[str] | None = None) -> int:
    args = parser().parse_args(argv)
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
